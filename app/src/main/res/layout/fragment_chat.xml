<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Messages List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/cv_attachment_preview_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Welcome Layout -->
    <LinearLayout
        android:id="@+id/ll_welcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_welcome_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin chào!"
            android:textColor="#333333"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chúng ta nên bắt đầu từ đâu nhỉ?"
            android:textColor="#1A1A1A"
            android:textSize="32sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_suggest_health"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏥 Kiểm tra sức khỏe hiện tại"
                android:textAllCaps="false"
                android:textColor="#444444"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                app:backgroundTint="#F0F4F9"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_suggest_heart"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❤️ Giải thích chỉ số nhịp tim"
                android:textAllCaps="false"
                android:textColor="#444444"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                app:backgroundTint="#F0F4F9"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_suggest_spo2"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💨 Nồng độ Oxy SpO2 là gì?"
                android:textAllCaps="false"
                android:textColor="#444444"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                app:backgroundTint="#F0F4F9"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_suggest_emergency"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🆘 Hướng dẫn khi gặp sự cố"
                android:textAllCaps="false"
                android:textColor="#444444"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:backgroundTint="#F0F4F9"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Attachment Menu Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_attachment_menu"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@+id/input_area"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/btn_menu_files"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tệp"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/orange_main" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

            <LinearLayout
                android:id="@+id/btn_menu_gallery"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ảnh"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="@color/orange_main" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

            <LinearLayout
                android:id="@+id/btn_menu_camera"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Camera"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/orange_main" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Attachment Preview -->
    <FrameLayout
        android:id="@+id/cv_attachment_preview_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/input_area">
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_attachment_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_preview"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop" />
                <ImageButton
                    android:id="@+id/btn_remove_attachment"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="2dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="@android:color/transparent"
                    app:tint="@color/app_orange" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Input Area Container -->
    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/bg_input_area_rounded"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Voice Recording Overlay -->
        <LinearLayout
            android:id="@+id/layout_voice_recording"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_stop_recording"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_button"
                android:src="@android:drawable/ic_media_pause"
                android:padding="10dp"
                app:tint="@color/orange_main" />

            <LinearLayout
                android:id="@+id/ll_waveform"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

            <ProgressBar
                android:id="@+id/pb_transcribing"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="@color/orange_main" />

            <ImageButton
                android:id="@+id/btn_send_voice"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_arrow_right"
                android:padding="10dp"
                app:tint="@color/orange_main" />

        </LinearLayout>

        <EditText
            android:id="@+id/et_message_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hỏi Healthy 365"
            android:background="@android:color/transparent"
            android:maxLines="6"
            android:inputType="textCapSentences|textMultiLine"
            android:paddingVertical="12dp"
            android:textSize="18sp"
            android:textColor="#1A1A1A"
            android:textColorHint="#757575" />

        <RelativeLayout
            android:id="@+id/layout_normal_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerVertical="true">

                <ImageButton
                    android:id="@+id/btn_attach"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_input_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/orange_main" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_mic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:background="@drawable/bg_circle_button"
                    android:padding="8dp"
                    app:tint="@color/orange_main" />

                <ImageButton
                    android:id="@+id/btn_send"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_right"
                    android:background="@drawable/bg_circle_button"
                    android:visibility="gone"
                    android:padding="8dp"
                    app:tint="@color/orange_main" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
