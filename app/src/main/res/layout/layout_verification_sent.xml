<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutVerificationSent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:gravity="center"
    android:visibility="gone">

    <ImageView
        android:id="@+id/ivSuccessIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:src="@android:drawable/ic_dialog_email"
        app:tint="#4CAF50" />

    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/ivSuccessIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="Đăng ký gần hoàn tất!"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSuccessMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvSuccessTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Chúng tôi đã gửi một link kích hoạt đến email của bạn. Vui lòng kiểm tra hộp thư và nhấn vào link để hoàn tất đăng ký."
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGoToLoginFromSuccess"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_below="@+id/tvSuccessMessage"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_button"
        android:text="Quay lại Đăng nhập"
        android:textColor="@android:color/white" />

</RelativeLayout>
