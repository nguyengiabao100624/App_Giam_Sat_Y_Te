<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone"
    tools:visibility="visible">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_otp"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Xác thực OTP"
                android:textColor="@color/orange_main"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtpInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Nhập mã OTP đã được gửi tới số điện thoại của bạn"
                android:textColor="@color/app_gray"
                android:textSize="16sp" />

            <!-- Using HorizontalScrollView to ensure 6 boxes fit on small screens without cut-off -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/otp_view_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtOtp1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                    <EditText
                        android:id="@+id/edtOtp2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                    <EditText
                        android:id="@+id/edtOtp3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                    <EditText
                        android:id="@+id/edtOtp4"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                    <EditText
                        android:id="@+id/edtOtp5"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />
                    <EditText
                        android:id="@+id/edtOtp6"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:layout_margin="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                </LinearLayout>
            </HorizontalScrollView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/btn_filled_orange"
                android:text="Xác thực"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Gửi lại mã sau 60s"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:id="@+id/tvResendOtp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Gửi lại mã OTP"
                android:textColor="@color/orange_main"
                android:textStyle="bold"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
